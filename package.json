{
  "name": "devfest-manager",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --no-hmr",
    "server": "json-server --watch db.json --port 3000 --delay 2000",
    "dev": "concurrently \"npm run server\" \"npm run start\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:devfest-manager": "node dist/devfest-manager/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-server": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/ssr": "^21.2.3",
    "@ngrx/operators": "^21.1.0",
    "@ngrx/signals": "^21.1.0",
    "express": "^5.2.1",
    "json-server": "^0.17.4",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "baseline-browser-mapping": "^2.10.10",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "6.0",
    "vitest": "^4.1.1"
  }
}
